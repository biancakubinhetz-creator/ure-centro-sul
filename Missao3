            border-bottom: 2px solid #d32f2f;
            padding-bottom: 16px;
          }
          .print-header h1 {
            color: #0a2f6c;
            font-size: 1.5rem;
          }
          .print-header p {
            color: #475569;
            font-size: 0.8rem;
          }
          .report-section {
            border-left: 3px solid #d32f2f;
            padding-left: 1rem;
            margin-bottom: 1.5rem;
          }
          .report-section h3 {
            font-size: 0.9rem;
            color: #0a2f6c;
            margin-bottom: 0.5rem;
          }
          .report-item {
            font-size: 0.8rem;
            margin-bottom: 6px;
            line-height: 1.5;
          }
          .report-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #d32f2f;
          }
          hr { margin: 1rem 0; }
        </style>
      </head>
      <body>
        <div class="print-header">
          <h1>🚶 Relatório da Missão 3 – Pontos de Parada</h1>
          <p>Jornada da Aprendizagem · URE CENTRO SUL - Seduc SP</p>
        </div>
        ${conteudo.outerHTML}
        <hr>
        <p style="text-align: center; font-size: 0.7rem; color: #64748b; margin-top: 20px;">Documento gerado em ${new Date().toLocaleString('pt-BR')}</p>
      </body>
      </html>
    `);
    doc.close();
    iframe.contentWindow.focus();
    iframe.contentWindow.print();
    setTimeout(() => { document.body.removeChild(iframe); }, 1000);
  }

  // Carregar dados salvos ao iniciar
  const dadosCarregados = carregarDoLocalStorage();
  if (dadosCarregados && (estado.nome || estado.passos > 0)) {
    let telaAtual = '';
    if (estado.passos === 1) telaAtual = 's1';
    else if (estado.passos === 2) telaAtual = 's2';
    else if (estado.passos === 3) telaAtual = 's3';
    else if (estado.passos === 4) telaAtual = 's4';
    else if (estado.passos === 5) telaAtual = 's5';
    else if (estado.passos >= 6) telaAtual = 'fim';
    if (telaAtual) {
      mostrarScreen(telaAtual);
      atualizarDots();
      let stepIdx = estado.passos === 1 ? 0 : estado.passos === 2 ? 1 : estado.passos === 3 ? 2 : estado.passos === 4 ? 3 : estado.passos === 5 ? 4 : 5;
      renderNav(telaAtual, stepIdx);
    } else {
      mostrarScreen('cadastro');
    }
  } else {
    mostrarScreen('cadastro');
  }

  // Auto-save em todas as mudanças de inputs
  function addAutoSaveEvents() {
    const allInputs = document.querySelectorAll('input, select, textarea');
    allInputs.forEach(el => {
      el.addEventListener('change', () => salvarParaLocalStorage());
      el.addEventListener('blur', () => salvarParaLocalStorage());
    });
    document.querySelectorAll('.checkbox-item input, .radio-item input').forEach(cb => {
      cb.addEventListener('change', () => salvarParaLocalStorage());
    });
  }
  addAutoSaveEvents();
</script>
</body>
