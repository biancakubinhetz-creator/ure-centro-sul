<!-- Botões CRUD (inferior esquerdo) -->
<div style="position: fixed; bottom: 24px; left: 24px; z-index: 10; display: flex; gap: 12px;">
  <button class="btn btn-danger" onclick="limparDados()" style="background: #fee2e2; color: #b91c1c;"><i class="fas fa-trash-alt"></i> Limpar todos os dados</button>
  <button class="btn btn-primary" onclick="salvarProgressoManual()" style="background: #0a2f6c;"><i class="fas fa-save"></i> Salvar progresso agora</button>
</div>
<!-- Botão fixo para imprimir relatório -->
<button class="print-btn" onclick="imprimirSomenteRelatorio()"><i class="fas fa-print"></i> Imprimir / Salvar PDF</button>

<script>
  let estado = { nome: '', escola: '', turma: '', componente: '', ciclo: '', passos: 0 };
  const TOTAL = 5;
  const ETAPAS = ['Reflexão inicial','Boa aula','Estratégias','3 primeiras aulas','Compromisso'];
  const STORAGE_KEY = 'missao3_jornada';

  // ========== CRUD LOCALSTORAGE ==========
  function salvarParaLocalStorage() {
    const dados = {
      identificacao: {
        nome: document.getElementById('inp-nome').value,
        escola: document.getElementById('inp-escola').value,
        turma: document.getElementById('inp-turma').value,
        componente: document.getElementById('inp-componente').value,
        ciclo: document.getElementById('inp-ciclo').value
      },
      passos: estado.passos,
      // textos
      s1q1: document.getElementById('s1q1').value,
      s1q2: document.querySelector('input[name="s1q2"]:checked') ? document.querySelector('input[name="s1q2"]:checked').value : '',
      s1q3: document.getElementById('s1q3').value,
      s2q1: document.querySelector('input[name="s2q1"]:checked') ? document.querySelector('input[name="s2q1"]:checked').value : '',
      s2q2: document.querySelector('input[name="s2q2"]:checked') ? document.querySelector('input[name="s2q2"]:checked').value : '',
      s2q3: document.getElementById('s2q3').value,
      s3q1: Array.from(document.querySelectorAll('input[name="s3q1"]:checked')).map(cb => cb.value),
      s3q2: Array.from(document.querySelectorAll('input[name="s3q2"]:checked')).map(cb => cb.value),
      s3q3: document.getElementById('s3q3').value,
      s5q1: document.getElementById('s5q1').value,
      s5q2: document.querySelector('input[name="s5q2"]:checked') ? document.querySelector('input[name="s5q2"]:checked').value : '',
      s5q3: document.getElementById('s5q3').value,
      s5q4: document.getElementById('s5q4').value,
      // aulas
      a1_tema: document.getElementById('a1-tema').value,
      a1_verif: document.getElementById('a1-verif').value,
      a1_dific: document.getElementById('a1-dific').value,
      a1_avanc: document.getElementById('a1-avanc').value,
      a2_tema: document.getElementById('a2-tema').value,
      a2_verif: document.getElementById('a2-verif').value,
      a2_dific: document.getElementById('a2-dific').value,
      a2_avanc: document.getElementById('a2-avanc').value,
      a3_tema: document.getElementById('a3-tema').value,
      a3_verif: document.getElementById('a3-verif').value,
      a3_dific: document.getElementById('a3-dific').value,
      a3_avanc: document.getElementById('a3-avanc').value
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(dados));
    console.log('✅ Dados salvos no localStorage');
  }

  function carregarDoLocalStorage() {
    const dadosRaw = localStorage.getItem(STORAGE_KEY);
    if (!dadosRaw) return false;
    try {
      const dados = JSON.parse(dadosRaw);
      // Identificação
      if (dados.identificacao) {
        document.getElementById('inp-nome').value = dados.identificacao.nome || '';
        document.getElementById('inp-escola').value = dados.identificacao.escola || '';
        document.getElementById('inp-turma').value = dados.identificacao.turma || '';
        document.getElementById('inp-componente').value = dados.identificacao.componente || '';
        document.getElementById('inp-ciclo').value = dados.identificacao.ciclo || '';
        estado.nome = dados.identificacao.nome || '';
        estado.escola = dados.identificacao.escola || '';
        estado.turma = dados.identificacao.turma || '';
        estado.componente = dados.identificacao.componente || '';
        estado.ciclo = dados.identificacao.ciclo || '';
      }
      estado.passos = dados.passos || 0;

      // Textos
      if (dados.s1q1) document.getElementById('s1q1').value = dados.s1q1;
      if (dados.s1q3) document.getElementById('s1q3').value = dados.s1q3;
      if (dados.s2q3) document.getElementById('s2q3').value = dados.s2q3;
      if (dados.s3q3) document.getElementById('s3q3').value = dados.s3q3;
      if (dados.s5q1) document.getElementById('s5q1').value = dados.s5q1;
      if (dados.s5q3) document.getElementById('s5q3').value = dados.s5q3;
      if (dados.s5q4) document.getElementById('s5q4').value = dados.s5q4;

      // Radios s1q2
      if (dados.s1q2) {
        let r = document.querySelector(`input[name="s1q2"][value="${escapeHtml(dados.s1q2)}"]`);
        if (r) r.checked = true;
      }
      if (dados.s2q1) {
        let r = document.querySelector(`input[name="s2q1"][value="${escapeHtml(dados.s2q1)}"]`);
        if (r) r.checked = true;
      }
      if (dados.s2q2) {
        let r = document.querySelector(`input[name="s2q2"][value="${escapeHtml(dados.s2q2)}"]`);
        if (r) r.checked = true;
      }
      if (dados.s5q2) {
        let r = document.querySelector(`input[name="s5q2"][value="${escapeHtml(dados.s5q2)}"]`);
        if (r) r.checked = true;
      }

      // Checkboxes
      if (dados.s3q1 && Array.isArray(dados.s3q1)) {
        document.querySelectorAll('input[name="s3q1"]').forEach(cb => {
          cb.checked = dados.s3q1.includes(cb.value);
        });
      }
      if (dados.s3q2 && Array.isArray(dados.s3q2)) {
        document.querySelectorAll('input[name="s3q2"]').forEach(cb => {
          cb.checked = dados.s3q2.includes(cb.value);
        });
      }

      // Aulas
      if (dados.a1_tema) document.getElementById('a1-tema').value = dados.a1_tema;
      if (dados.a1_verif) document.getElementById('a1-verif').value = dados.a1_verif;
      if (dados.a1_dific) document.getElementById('a1-dific').value = dados.a1_dific;
      if (dados.a1_avanc) document.getElementById('a1-avanc').value = dados.a1_avanc;
      if (dados.a2_tema) document.getElementById('a2-tema').value = dados.a2_tema;
      if (dados.a2_verif) document.getElementById('a2-verif').value = dados.a2_verif;
      if (dados.a2_dific) document.getElementById('a2-dific').value = dados.a2_dific;
      if (dados.a2_avanc) document.getElementById('a2-avanc').value = dados.a2_avanc;
      if (dados.a3_tema) document.getElementById('a3-tema').value = dados.a3_tema;
      if (dados.a3_verif) document.getElementById('a3-verif').value = dados.a3_verif;
      if (dados.a3_dific) document.getElementById('a3-dific').value = dados.a3_dific;
      if (dados.a3_avanc) document.getElementById('a3-avanc').value = dados.a3_avanc;

      atualizarDots();
      return true;
    } catch(e) { console.error('Erro ao carregar dados', e); return false; }
  }

  function limparDados() {
    if (confirm('⚠️ Tem certeza que deseja apagar TODOS os dados salvos? Essa ação não pode ser desfeita.')) {
      localStorage.removeItem(STORAGE_KEY);
      location.reload();
    }
  }

  function salvarProgressoManual() {
    salvarParaLocalStorage();
    alert('✅ Progresso salvo com sucesso!');
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // ========== FUNÇÕES EXISTENTES (adaptadas) ==========
  function iniciarMissao() {
    let n = document.getElementById('inp-nome').value.trim();
    let e = document.getElementById('inp-escola').value.trim();
    let t = document.getElementById('inp-turma').value.trim();
    let c = document.getElementById('inp-componente').value;
    let ci = document.getElementById('inp-ciclo').value;
    if (!n || !e || !t || !c || !ci) { alert('Preencha todos os campos para começar!'); return; }
    estado.nome = n; estado.escola = e; estado.turma = t; estado.componente = c; estado.ciclo = ci;
    salvarParaLocalStorage();
    mostrarScreen('s1'); atualizarDots(); renderNav('s1', 0);
  }

  function mostrarScreen(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('screen-' + id).classList.add('active');
    window.scrollTo(0, 0);
  }

  function atualizarDots() {
    let dots = document.getElementById('progress-dots');
    dots.innerHTML = '';
    for (let i = 0; i < TOTAL; i++) {
      let d = document.createElement('div');
      d.className = 'dot' + (i < estado.passos ? ' done' : i === estado.passos ? ' current' : '');
      dots.appendChild(d);
    }
    let pct = Math.round((estado.passos / TOTAL) * 100);
    document.getElementById('xp-bar').style.width = pct + '%';
    document.getElementById('xp-label').textContent = estado.passos + ' / ' + TOTAL + ' paradas desenhadas';
  }

  function renderNav(screenId, stepIdx) {
    let nav = document.getElementById('nav-' + screenId);
    if (!nav) return;
    nav.innerHTML = '';
    ETAPAS.forEach((nome, i) => {
      let btn = document.createElement('div');
      btn.className = 'nav-step' + (i < stepIdx ? ' done-nav' : i === stepIdx ? ' current-nav' : '');
      btn.textContent = (i + 1) + '. ' + nome;
      nav.appendChild(btn);
    });
  }

  function avancar(de, para, passoAtual) {
    if (passoAtual >= estado.passos) estado.passos = passoAtual + 1;
    salvarParaLocalStorage();
    atualizarDots();
    mostrarScreen(para);
    let idx = passoAtual + 1;
    if (idx <= TOTAL) renderNav(para, idx);
  }

  function getChecked(name) {
    let vals = [];
    document.querySelectorAll('input[name="' + name + '"]:checked').forEach(cb => vals.push(cb.value));
    return vals.length ? vals.join('; ') : 'Nenhum item marcado';
  }
  function getRadio(name) {
    let el = document.querySelector('input[name="' + name + '"]:checked');
    return el ? el.value : 'Não respondido';
  }
  function getVal(id) { let el = document.getElementById(id); return el ? el.value.trim() || 'Não preenchido' : 'Não preenchido'; }

  function gerarRelatorio() {
    let data = new Date();
    let dataStr = data.toLocaleDateString('pt-BR') + ' às ' + data.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
    let html = '';
    html += `<div class="report-section"><h3><i class="fas fa-user"></i> Identificação</h3><div class="report-item"><span class="report-label">Professor(a): </span>${estado.nome}</div><div class="report-item"><span class="report-label">Escola: </span>${estado.escola}</div><div class="report-item"><span class="report-label">Turma: </span>${estado.turma}</div><div class="report-item"><span class="report-label">Componente: </span>${estado.componente}</div><div class="report-item"><span class="report-label">Ciclo: </span>${estado.ciclo}</div><div class="report-item"><span class="report-label">Data: </span>${dataStr}</div></div>`;
    html += `<div class="report-section"><h3><i class="fas fa-comment-dots"></i> Parada 1 — Reflexão inicial</h3><div class="report-item"><span class="report-label">Como percebe aprendizagem: </span>${getVal('s1q1')}</div><div class="report-item"><span class="report-label">O que faz quando não acompanham: </span>${getRadio('s1q2')}</div><div class="report-item"><span class="report-label">O que diferencia boa aula: </span>${getVal('s1q3')}</div></div>`;
    html += `<div class="report-section"><h3><i class="fas fa-chalkboard-teacher"></i> Parada 2 — Autoavaliação</h3><div class="report-item"><span class="report-label">Maior ponto forte: </span>${getRadio('s2q1')}</div><div class="report-item"><span class="report-label">Aspecto a desenvolver: </span>${getRadio('s2q2')}</div><div class="report-item"><span class="report-label">Situação de ajuste recente: </span>${getVal('s2q3')}</div></div>`;
    html += `<div class="report-section"><h3><i class="fas fa-search"></i> Parada 3 — Estratégias</h3><div class="report-item"><span class="report-label">Verificações usadas: </span>${getChecked('s3q1')}</div><div class="report-item"><span class="report-label">Ajustes usados: </span>${getChecked('s3q2')}</div><div class="report-item"><span class="report-label">Estratégia nova: </span>${getVal('s3q3')}</div></div>`;
    html += `<div class="report-section"><h3><i class="fas fa-clipboard-list"></i> Parada 4 — 3 primeiras aulas</h3>`;
    for (let i = 1; i <= 3; i++) {
      html += `<div style="background:#f8fafc;border-radius:20px;padding:0.75rem;margin-bottom:0.75rem;"><h4 style="font-weight:700;">Aula ${i}: ${getVal(`a${i}-tema`)}</h4><div class="report-item"><span class="report-label">Verificação: </span>${getVal(`a${i}-verif`)}</div><div class="report-item"><span class="report-label">Dificuldades: </span>${getVal(`a${i}-dific`)}</div><div class="report-item"><span class="report-label">Avanços: </span>${getVal(`a${i}-avanc`)}</div></div>`;
    }
    html += `</div><div class="report-section"><h3><i class="fas fa-heart"></i> Parada 5 — Compromisso</h3><div class="report-item"><span class="report-label">Compromisso: </span>${getVal('s5q1')}</div><div class="report-item"><span class="report-label">Sentimento: </span>${getRadio('s5q2')}</div><div class="report-item"><span class="report-label">Apoio necessário: </span>${getVal('s5q3')}</div><div class="report-item"><span class="report-label">Palavra-resumo: </span><strong>${getVal('s5q4')}</strong></div></div>`;
    document.getElementById('relatorio-conteudo').innerHTML = html;
    mostrarScreen('relatorio');
  }

  function imprimirSomenteRelatorio() {
    const conteudo = document.getElementById('relatorio-conteudo');
    if (!conteudo || !conteudo.innerHTML.trim() || conteudo.innerHTML === '') {
      alert('Nenhum relatório foi gerado ainda. Complete a missão e gere o relatório primeiro.');
      return;
    }
    const iframe = document.createElement('iframe');
    iframe.style.position = 'absolute';
    iframe.style.width = '0';
    iframe.style.height = '0';
    iframe.style.border = 'none';
    document.body.appendChild(iframe);
    const doc = iframe.contentWindow.document;
    doc.open();
    doc.write(`
      <!DOCTYPE html>
      <html>
      <head>
        <meta charset="UTF-8">
        <title>Relatório Missão 3 - Pontos de Parada</title>
        <style>
          * { margin: 0; padding: 0; box-sizing: border-box; }
